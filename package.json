{
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --filter='./apps/*' --filter='./packages/*'",
    "dev": "turbo run dev --filter='./apps/*' --filter='./packages/*'",
    "lint": "turbo run lint --filter='./apps/*' --filter='./packages/*'",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test --filter='./apps/*' --filter='./packages/*'"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@types/bcrypt": "^6.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.6",
    "canvas-confetti": "^1.9.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "^4.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "geist": "^1.7.0",
    "googleapis": "^171.4.0",
    "jwt-decode": "^4.0.0",
    "passport-jwt": "^4.0.1",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.75.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
